# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sockpuppet

# Redis
REDIS_URL=redis://localhost:6379

# App
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development

# Optional
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# LLM Analysis (Optional - enhances detection accuracy)
LLM_ANALYSIS_ENABLED=false
LLM_PROVIDER=none  # Options: ollama, openai, anthropic, none
LLM_MODEL=  # e.g., llama3.2 (ollama), gpt-4o-mini (openai), claude-3-haiku-20240307 (anthropic)
LLM_API_KEY=  # Required for openai/anthropic
OLLAMA_URL=http://localhost:11434  # For local Ollama instance
